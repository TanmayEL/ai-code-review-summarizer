# Copy this to .env and fill in your values.

# --- Required ---
ANTHROPIC_API_KEY=your-api-key-here

# --- Optional ---
# GitHub token - not needed for public repos, but you'll hit
# the 60 req/hour unauthenticated limit fast. Get one at:
# https://github.com/settings/tokens (no scopes needed for public repos)
# GITHUB_TOKEN=ghp_...

# Path to the RAG index (default: data/rag_index)
# RAG_INDEX_DIR=data/rag_index

# DEBUG=0
