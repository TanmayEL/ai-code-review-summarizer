# Copy this to .env and fill in your values.
# The app reads this automatically via python-dotenv.

# --- Required ---
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# --- Optional ---
# Path to the RAG index (default: data/rag_index)
# RAG_INDEX_DIR=data/rag_index

# Set to 1 to try CUDA (default 1, falls back to CPU automatically)
# USE_CUDA=0

# Set to 1 for verbose debug logging
# DEBUG=0
